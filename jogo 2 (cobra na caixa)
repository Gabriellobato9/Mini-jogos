#include <stdio.h>
#include <stdlib.h>
#include <time.h>

int main() {
    srand(time(NULL)); // Inicializa o gerador de números aleatórios

    int opcMENU;
    int i; // Variável de controle para os laços declarada fora para compatibilidade

    do {
        printf("\nCOBRA NA CAIXA!\n");
        printf("1 - Jogar\n2 - Sair\nEscolha: ");
        scanf("%d", &opcMENU);
        while (getchar() != '\n'); // Limpa o buffer de entrada

        if (opcMENU == 1) {
            int botao, cobra, escolha, jogAtual;
            int caixas[5] = {0, 0, 0, 0, 0}; // 0 = fechada, 1 = aberta
            int fimDeJogo = 0;

            // 1. Sorteio das caixas
            botao = rand() % 5 + 1;
            do {
                cobra = rand() % 5 + 1;
            } while (cobra == botao);

            // 2. Escolha dos personagens
            const char* personagens[] = {"Saldanha", "Lobato", "Girotto", "Jose", "Mumia", "Aleixo", "Bieri"};
            int n1, n2;

            printf("\nPersonagens disponiveis:\n");
            // CORREÇÃO: i já declarada no início do main
            for (i = 0; i < 7; i++) {
                printf("%d - %s\n", i + 1, personagens[i]);
            }

            printf("Jogador 1, escolha seu personagem (1-7): ");
            scanf("%d", &n1);
            while (getchar() != '\n'); 
            
            printf("Jogador 2, escolha seu personagem (1-7): ");
            scanf("%d", &n2);
            while (getchar() != '\n'); 

            // 3. Sorteia quem começa
            jogAtual = rand() % 2 + 1;
            printf("\nO sistema sorteou: JOGADOR %d (%s) comeca!\n", jogAtual, (jogAtual == 1) ? personagens[n1 - 1] : personagens[n2 - 1]);

            // 4. Loop de Turnos
            while (fimDeJogo == 0) {
                printf("\n--- TURNO DO JOGADOR %d (%s) ---", jogAtual, (jogAtual == 1) ? personagens[n1 - 1] : personagens[n2 - 1]);
                printf("\nCaixas disponiveis: ");
                
                // CORREÇÃO: Uso da variável i declarada externamente
                for (i = 0; i < 5; i++) {
                    if (caixas[i] == 0) {
                        printf("[%d] ", i + 1);
                    }
                }

                printf("\nEscolha uma caixa: ");
                scanf("%d", &escolha);
                while (getchar() != '\n'); 

                if (escolha < 1 || escolha > 5 || caixas[escolha - 1] == 1) {
                    printf("Escolha invalida ou caixa ja aberta! Tente novamente.\n");
                    continue; 
                }

                caixas[escolha - 1] = 1;

                if (escolha == botao) {
                    printf("PARABENS! Voce encontrou o BOTAO e a porta abriu! JOGADOR %d (%s) VENCEU!\n", jogAtual, (jogAtual == 1) ? personagens[n1 - 1] : personagens[n2 - 1]);
                    fimDeJogo = 1;
                } else if (escolha == cobra) {
                    printf("QUE AZAR! Voce encontrou a COBRA! JOGADOR %d (%s) PERDEU!\n", jogAtual, (jogAtual == 1) ? personagens[n1 - 1] : personagens[n2 - 1]);
                    fimDeJogo = 1;
                } else {
                    printf("A caixa estava vazia... O turno passa.\n");
                    jogAtual = (jogAtual == 1) ? 2 : 1;
                }
            }

            printf("\nDeseja:\n1 - Jogar Novamente\n2 - Voltar ao Menu\nEscolha: ");
            int subOpc;
            scanf("%d", &subOpc);
            while (getchar() != '\n');
            
            if (subOpc == 1) {
                opcMENU = 1; // Mantém no loop de jogo
            } else {
                opcMENU = 0; // Volta para o menu principal (diferente de 2 para não sair do programa)
            }
        }
    } while (opcMENU != 2);

    return 0;
}
