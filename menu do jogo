// --- PROTÓTIPOS ---

void jogoPerguntaResposta();
void jogoCobraNaCaixa();
void jogoGousmasWar();
int lerEntrada(int min, int max); // Função do 3º jogo

// ================
//  MENU PRINCIPAL
// ================

int main() {
    srand(time(NULL)); 
    int opcaoMenuPrincipal;

    do {
        system("cls");
        printf("=================================\n");
        printf("         SISTEMA DE JOGOS        \n");
        printf("=================================\n");
        printf("1: Pergunta e Resposta\n");
        printf("2: Cobra na Caixa!\n");
        printf("3: Gousmas War\n");
        printf("4: Sair\n");
        printf("---------------------------------\n");
        printf("Escolha uma opcao: ");
        
        scanf("%d", &opcaoMenuPrincipal);
        while (getchar() != '\n'); // Limpa o buffer

        // Avalia a variavel 'opcaoMenuPrincipal' para decidir qual caminho (case) seguir
        switch (opcaoMenuPrincipal) { 
            
            // Se o valor digitado pelo usuario for 1, entra neste bloco
            case 1: 
                system("cls"); // Limpa a tela do terminal (Clear Screen) para organizar o visual
                printf("\n[DESCRICAO]: Teste seus conhecimentos!\n"); // Exibe a descricao do jogo
                Sleep(3000); // Pausa a execucao por 3000 milissegundos (3 segundos) para o jogador ler
                jogoPerguntaResposta(); // Chama a funcao que contem o codigo do 1º jogo
                break; // Obrigatorio: Encerra o 'switch' para impedir que o codigo vaute para o 'case 2'

            // Se o valor digitado for 2, entra neste bloco
            case 2:
                system("cls"); // Limpa a tela novamente
                printf("\n[DESCRICAO]: Encontre o botao e evite a cobra!\n"); 
                Sleep(3000); // Aguarda 3 segundos
                jogoCobraNaCaixa(); // Chama a funcao que contem o codigo do 2º jogo
                break; // Encerra o 'switch' e volta para o menu

            // Se o valor digitado for 3, entra neste bloco
            case 3:
                system("cls"); // Limpa a tela
                printf("\n[DESCRICAO]: Batalha de gosmas!\n");
                Sleep(3000); // Aguarda 3 segundos
                jogoGousmasWar(); // Chama a funcao que contem o codigo do 3º jogo
                break; // Encerra o 'switch'

            // Se o valor digitado for 4 (Sair)
            case 4:
                // Apenas exibe a mensagem de despedida. Nao precisa de 'Sleep' ou limpar tela.
                printf("\nSaindo do sistema... Ate logo!\n"); 
                break; // Encerra o 'switch'

            // O 'default' funciona como um "Se nenhuma das opcoes acima for verdadeira"
            default:
                // Exibe uma mensagem de erro caso o usuario digite 5, 9, letras, etc.
                printf("\nOpcao invalida! Tente novamente.\n"); 
                Sleep(2000); // Aguarda 2 segundos para o usuario conseguir ler o erro
                // Nao precisa de 'break' aqui pois e a ultima opcao do switch
        }

    // Condicao do laco 'do...while' (Faca... Enquanto)
    // Ele avalia: A opcao escolhida e diferente (!=) de 4? 
    // Se SIM (ex: escolheu 1), ele repete o menu inteiro. Se NAO (escolheu 4), o laco se quebra e o programa fecha.
    } while (opcaoMenuPrincipal != 4);
    return 0;
}

